      isLeftPortrait: 1
      text: "\u6B63\u597D\u5B66\u6821\u4E5F\u5728\u8FD9\u8FB9\uFF0C\u6211\u8981\u597D\u597D\u4F11\u606F\u4E00\u5C0F\u6BB5\u65F6\u95F4\uFF0C\u6211\u8FD8\u8981\u51C6\u5907\u6BD5\u4E1A\u8BBE\u8BA1\u554A......"
