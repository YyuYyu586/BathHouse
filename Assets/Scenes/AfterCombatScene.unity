    - speakerName: "\u5B9E\u4E60\u751F\u9F20\u9F20"
      portrait: {fileID: 21300000, guid: 9ea448a3cebae334db0f920b7e3992d2, type: 3}
      isLeftPortrait: 1
      text: "\u9F20\u53D4\uFF0C\u591A\u4E8F\u4F60\u4ECA\u65E9\u628A\u8DEF\u53E3\u7684\u79EF\u6C34\u6E05\u7406\u4E86\uFF0C\u4E0D\u7136\u6211\u8D76\u65E9\u9AD8\u5CF0\u975E\u5F97\u6454\u4E00\u8DE4\u4E0D\u53EF\u54C8\u54C8\u54C8\uFF01\u6700\u8FD1\u4E0B\u96E8\u90A3\u8FB9\u8001\u662F\u6E7F\u6F09\u6F09\u7684......"
      backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
    - speakerName: "\u5B9E\u4E60\u751F\u9F20\u9F20"
