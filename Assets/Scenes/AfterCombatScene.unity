      isLeftPortrait: 1
      text: "\u6211\u4ECA\u5929\u672C\u6765\u60F3\u7740\u518D\u9001\u8FD9\u4E00\u4E0B\uFF0C\u7ED9\u6211\u95FA\u5973\u4E70\u751F\u65E5\u793C\u7269\u7684...\uFF08\u4ECE\u53E3\u888B\u91CC\u638F\u51FA\u4E00\u4E2A\u634F\u76B1\u7684\u5C0F\u793C\u76D2\uFF09"
