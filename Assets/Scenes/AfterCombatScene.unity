    - speakerName: "\u5C0F\u798F"
      portrait: {fileID: 21300000, guid: ed4e5cfa213d7eb40bc58c908eb575a0, type: 3}
      isLeftPortrait: 0
      text: "\u4EC0\u4E48\u56DE\u4E8B\uFF01\uFF1F\u90A3\u4E9B\u539A\u539A\u7684\u4E1C\u897F...\u53C8\u8D34\u56DE\u4E86\u4ED6\u7684\u80CC\u4E0A\u4E86"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u91D1\u5AC2"
      portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
      isLeftPortrait: 1
      text: "\u522B\u770B\u4E86\uFF0C\u8116\u5B50\u90FD\u8981\u4F38\u6210\u957F\u9888\u9E7F\u4E86\u3002"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u91D1\u5AC2"
      portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
      isLeftPortrait: 1
      text: "\u4ED6\u5728\u90A3\u628A\u6905\u5B50\u4E0A\u5750\u4E00\u5929\uFF0C\u90A3\u5757\u4E1C\u897F\u5C31\u4E00\u76F4\u5728\uFF0C\u4E5F\u662F\u4E3A\u4E86\u4FDD\u62A4\u81EA\u5DF1\u5427\uFF0C\u4EE5\u81EA\u5DF1\u7684\u672C\u6211\u9762\u5BF9\u8FD9\u4E9B\u4E1C\u897F\u662F\u4E2A\u4EBA\u90FD\u53D7\u4E0D\u4E86\u3002"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u5C0F\u798F"
      portrait: {fileID: 21300000, guid: ed4e5cfa213d7eb40bc58c908eb575a0, type: 3}
      isLeftPortrait: 0
      text: "\u53EF\u521A\u624D\u660E\u660E\u90FD\u6D17\u5E72\u51C0\u4E86\u2026"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u91D1\u5AC2"
      portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
      isLeftPortrait: 1
      text: "\u884C\u4E86\uFF0C\u6536\u8D77\u4F60\u90A3\u60B2\u5929\u60AF\u4EBA\u7684\u8868\u60C5\u3002\u81F3\u5C11\u8FD9\u4E00\u5C0F\u4F1A\u513F\uFF0C\u4ED6\u81F3\u5C11\u662F\u7545\u5FEB\u7684\u3002"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u91D1\u5AC2"
      portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
      isLeftPortrait: 1
      text: "\u4ECA\u5929\u5C31\u8FD9\u6837\uFF0C\u6211\u60F3\u6536\u5DE5\u4E86\uFF0C\u5FD8\u8BB0\u8BF4\u4E86\uFF0C\u6BCF\u4E2A\u670810\u53F7\u53D1\u5DE5\u8D44\u54C8\uFF01"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u91D1\u5AC2"
      portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
      isLeftPortrait: 1
      text: "\u6EDA\u56DE\u5BB6\u7761\u89C9\u53BB\uFF0C\u4F60\u4E0D\u5ACC\u7D2F\u8001\u5A18\u6570\u94B1\u90FD\u5FEB\u6570\u9EBB\u4E86\u3002"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
  - dayName: Day 4
