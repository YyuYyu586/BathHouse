    - speakerName: "\u6211\u662F\u65C1\u767D"
      portrait: {fileID: 0}
      isLeftPortrait: 0
      text: "\u53EE\u549A\uFF01\u201C@\u6240\u6709\u4EBA\uFF1A\u4E09\u5341\u5206\u949F\u540E\u62C9\u4E2A\u4F1A\u5BF9\u9F50\u4E00\u4E0B\u4E0A\u5468\u8FDB\u5EA6\uFF01\u201D"
