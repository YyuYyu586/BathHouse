      isLeftPortrait: 1
      text: "\u6211\u4E5F\u60F3\u81EA\u7531\uFF0C\u4F46\u662F\u8FD9\u4E0D\u662F\u60F3\u5E72\u4EC0\u4E48\u5C31\u5E72\u4EC0\u4E48"
