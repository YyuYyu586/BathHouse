      isLeftPortrait: 1
      text: "\u5728\u4F60\u8FD9\u513F\u6D17\u5E72\u51C0\u4E86\uFF0C\u6211\u5C31\u8981\u5E72\u5E72\u51C0\u51C0\u56DE\u5BB6\u597D\u597D\u966A\u5BB6\u4EBA\u4E86\u3002"
