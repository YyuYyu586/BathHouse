  m_Script: {fileID: 11500000, guid: 01c61121a3cc65646b10b39978fca876, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueManager: {fileID: 1041150348}
  afterCombatDialogues:
  - dayName: Day 2
    lines:
    - speakerName: "\u5B9E\u4E60\u751F\u9F20\u9F20"
      portrait: {fileID: 21300000, guid: 9ea448a3cebae334db0f920b7e3992d2, type: 3}
      isLeftPortrait: 1
      text: "\u2026\u2026\u547C\u3002\u539F\u6765\u6211\u7684\u8116\u5B50\u8FD8\u662F\u80FD\u8F6C\u7684\u554A"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u5C0F\u798F"
      portrait: {fileID: 21300000, guid: ed4e5cfa213d7eb40bc58c908eb575a0, type: 3}
      isLeftPortrait: 0
      text: "\u6211\u61C2\u4F60\uFF0C\u6211\u4EEC\u8FD9\u513F\u7684\u670D\u52A1\u4E0D\u9519\u5427\uFF0C\u8C01\u80FD\u60F3\u5230\u6211\u524D\u51E0\u5929\u8FD8\u5728\u8FD9\u9644\u8FD1\u52A0\u73ED\u5462......"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u5B9E\u4E60\u751F\u9F20\u9F20"
      portrait: {fileID: 21300000, guid: 9ea448a3cebae334db0f920b7e3992d2, type: 3}
      isLeftPortrait: 1
      text: "\u6CA1\u60F3\u5230\u6211\u4EEC\u66FE\u7ECF\u4E5F\u662F\u540C\u75C5\u76F8\u601C......"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u5B9E\u4E60\u751F\u9F20\u9F20"
      portrait: {fileID: 21300000, guid: 9ea448a3cebae334db0f920b7e3992d2, type: 3}
      isLeftPortrait: 1
      text: "\u751A\u81F3\u6BCF\u5929\u5FD9\u5230\u8FDE\u996D\u90FD\u5FD8\u8BB0\u5403......"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u6211\u662F\u65C1\u767D"
      portrait: {fileID: 0}
      isLeftPortrait: 0
      text: "\u5B9E\u4E60\u751F\u9F20\u9F20\u653E\u5728\u4E00\u65C1\u7684\u624B\u673A\uFF1A\u300C@\u6240\u6709\u4EBA
        \u660E\u5929\u4E0A\u5348\u524D\u628A\u7ADE\u54C1\u5206\u6790\u53D1\u51FA\u6765\uFF01\u300D"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u5B9E\u4E60\u751F\u9F20\u9F20"
      portrait: {fileID: 21300000, guid: 9ea448a3cebae334db0f920b7e3992d2, type: 3}
      isLeftPortrait: 1
      text: "\u5176\u5B9E\u6211\u60F3\u4E86\u5F88\u4E45\uFF0C\u6765\u4F60\u8FD9\u91CC\u4EAB\u53D7\u4E86\u8FD9\u4E48\u4E00\u4E0B\uFF0C\u4E5F\u60F3\u6709\u70B9\u60F3\u4E0B\u5B9A\u51B3\u5FC3\u4E86"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u5B9E\u4E60\u751F\u9F20\u9F20"
      portrait: {fileID: 21300000, guid: 9ea448a3cebae334db0f920b7e3992d2, type: 3}
      isLeftPortrait: 1
      text: "\u53CD\u6B63\u6211\u53EA\u662F\u6765\u5B9E\u4E60\u7684\uFF0C\u8FD9\u4E2A\u5730\u65B9\u4E0D\u597D\u81EA\u6709\u4E0B\u4E00\u4E2A\u5F85\u9047\u66F4\u597D\u7684\u5730\u65B9\uFF0C\u6211\u4E5F\u5DF2\u7ECF\u5F97\u5230\u8FD9\u4EFD\u7ECF\u9A8C\u4E86......"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u5B9E\u4E60\u751F\u9F20\u9F20"
      portrait: {fileID: 21300000, guid: 9ea448a3cebae334db0f920b7e3992d2, type: 3}
      isLeftPortrait: 1
      text: "\u6240\u4EE5\uFF01"
