      portrait: {fileID: 21300000, guid: ed4e5cfa213d7eb40bc58c908eb575a0, type: 3}
      isLeftPortrait: 0
      text: "\u6BCF\u5929\u8D77\u65E9\u8D2A\u9ED1\uFF0C\u628A\u8FD9\u57CE\u5E02\u6536\u62FE\u5F97\u5E72\u5E72\u51C0\u51C0\uFF0C\u8981\u662F\u6CA1\u6709\u4F60\uFF0C\u9F20\u4EEC\u8FDE\u5757\u5E72\u51C0\u7684\u5730\u513F\u90FD\u8E29\u4E0D\u4E0A\uFF01"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u5C0F\u798F"
      portrait: {fileID: 0}
      isLeftPortrait: 0
      text: "\u6211\u77E5\u9053\u8FD9\u9644\u8FD1\u6709\u5927\u5B66\uFF0C\u6240\u4EE5\u521A\u597D\u4E5F\u6709\u5730\u644A\uFF0C\u90A3\u4E00\u7247\u6700\u96BE\u6E05\u7406\u4E86\u5427......"
      backgroundImage: {fileID: 0}
    - speakerName: "\u5C0F\u798F"
      portrait: {fileID: 21300000, guid: ed4e5cfa213d7eb40bc58c908eb575a0, type: 3}
      isLeftPortrait: 0
      text: "\u6240\u4EE5\u6211\u4EEC\u8FD9\u513F\uFF0C\u5C31\u662F\u4E3A\u4E86\u6D17\u6389\u9F20\u9F20\u4EEC\u8EAB\u4E0A\u7684\u75B2\u60EB\u4E0E\u59D4\u5C48\u800C\u5B58\u5728\uFF0C\u5E0C\u671B\u4F60\u6EE1\u610F\u3002"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u6E05\u6D01\u5DE5"
      portrait: {fileID: 21300000, guid: d1e45009b3af2f544aa17ff7502a591c, type: 3}
      isLeftPortrait: 1
      text: "\u54CE...\u8FD9\u8BDD\u8BF4\u5F97\u6211\u5FC3\u91CC\u771F\u662F...\u4ECA\u5929\u771F\u662F\u8C22\u8C22\u4F60\u4E86\uFF0C\u5C0F\u5E08\u5085\u3002"
      backgroundImage: {fileID: 21300000, guid: a29cf2768c2215f4b9c2b86fafc9670f, type: 3}
    - speakerName: "\u5C0F\u798F"
      portrait: {fileID: 21300000, guid: ed4e5cfa213d7eb40bc58c908eb575a0, type: 3}
      isLeftPortrait: 0
      text: "\u591A\u5927\u70B9\u4E8B\u513F\uFF01\u6D17\u5B8C\u8212\u8212\u670D\u670D\u7761\u4E00\u89C9\uFF0C\u4EE5\u540E\u7D2F\u4E86\u968F\u65F6\u6765\uFF01"
