      isLeftPortrait: 1
      text: "\u597D\uFF0C\u6C38\u8FDC\u4E0D\u8981\u653E\u5F03\uFF0C\u4F46\u4E5F\u4E0D\u8981\u5FD8\u8BB0\u4F11\u606F"
