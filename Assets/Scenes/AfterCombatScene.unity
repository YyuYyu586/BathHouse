    - speakerName: "\u6211\u662F\u65C1\u767D"
      portrait: {fileID: 0}
      isLeftPortrait: 0
      text: "\u7B2C\u4E8C\u5929\u591C\u665A\uFF0C\u6E05\u6D01\u5DE5\u9F20\u9F20\u6B63\u5728\u8857\u4E0A\u626B\u5730\u3002"
