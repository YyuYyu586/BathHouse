      isLeftPortrait: 0
      text: "\u53D4\uFF0C\u60A8\u522B\u7BA1\u5916\u5934\u90A3\u4E9B\u4E0D\u957F\u773C\u7684\u4EBA\u600E\u4E48\u770B\u3002"
