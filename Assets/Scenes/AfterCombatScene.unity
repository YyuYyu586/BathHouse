      isLeftPortrait: 1
      text: "\u5373\u4F7F\u6211\u73B0\u5728\u6709\u5B58\u6B3E\uFF0C\u4F46\u6211\u4E5F\u4E0D\u80FD\u5750\u5403\u5C71\u7A7A..."
