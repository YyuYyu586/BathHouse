      isLeftPortrait: 1
      text: "\u7ED9\uFF0C\u521A\u4E70\u7684\u70ED\u8336\uFF0C\u8F9B\u82E6\u4E86\uFF01"
      backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
    - speakerName: "\u6E05\u6D01\u5DE5"
      portrait: {fileID: 21300000, guid: d1e45009b3af2f544aa17ff7502a591c, type: 3}
      isLeftPortrait: 1
      text: "\u8C22\u8C22\u4F60\u5C0F\u9F20\uFF01\u4F60\u7684\u5FC3\u610F\u6211\u6536\u4E0B\u4E86\u3002"
