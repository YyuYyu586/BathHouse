  m_Name: 
  m_EditorClassIdentifier: 
  dialogueManager: {fileID: 1041150348}
  openingLines:
  - speakerName: "\u6211\u662F\u65C1\u767D"
    portrait: {fileID: 0}
    isLeftPortrait: 0
    text: "\u6DF1\u591C\u3002"
    backgroundImage: {fileID: 21300000, guid: 9b1e4d166df7fb0458ad0d4a1458a9ab, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\u2026\u2026\u53C8\u6539\u56DE\u7B2C\u4E00\u7248\uFF1F"
    backgroundImage: {fileID: 21300000, guid: 9b1e4d166df7fb0458ad0d4a1458a9ab, type: 3}
  - speakerName: "\u8001\u677F"
    portrait: {fileID: 0}
    isLeftPortrait: 0
    text: "\u8F9B\u82E6\u5927\u5BB6\u518D\u4F18\u5316\u4E00\u4E0B\u3002"
    backgroundImage: {fileID: 21300000, guid: 9b1e4d166df7fb0458ad0d4a1458a9ab, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\u2026\u2026\u5237\u4F1A\u513FX\u97F3\u5427"
    backgroundImage: {fileID: 21300000, guid: 9b1e4d166df7fb0458ad0d4a1458a9ab, type: 3}
  - speakerName: "\u6211\u662F\u65C1\u767D"
    portrait: {fileID: 0}
    isLeftPortrait: 0
    text: "\u3010\u9F20\u9F20\u5927\u6FA1\u5802\uFF5C\u65B0\u4EBA\u4F53\u9A8C\u5238
      \u9650\u65F619.9\u3011"
    backgroundImage: {fileID: 21300000, guid: 9b1e4d166df7fb0458ad0d4a1458a9ab, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\u6FA1\u5802\uFF1F"
    backgroundImage: {fileID: 21300000, guid: 9b1e4d166df7fb0458ad0d4a1458a9ab, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\u2026\u2026\u73B0\u5728\u54EA\u8FD8\u6709\u65F6\u95F4\u6CE1\u6FA1\u3002"
    backgroundImage: {fileID: 21300000, guid: 9b1e4d166df7fb0458ad0d4a1458a9ab, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\u7B97\u4E86,\u81F3\u5C11\u4ECA\u5929\u4E0D\u60F3\u518D\u770B\u5DE5\u4F5C\u7FA4\u4E86\u3002"
    backgroundImage: {fileID: 21300000, guid: 9b1e4d166df7fb0458ad0d4a1458a9ab, type: 3}
  - speakerName: "\u6211\u662F\u65C1\u767D"
    portrait: {fileID: 0}
    isLeftPortrait: 0
    text: "\u6FA1\u5802\u7684\u706F\u724C\u8FD8\u5728\u4EAE\u7740\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u6B38,\u600E\u4E48\u53C8\u6765,\u672C\u6765\u90FD\u5FEB\u6253\u70CA\u4E86..."
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u6B22\u8FCE\u5149\u4E34\uFF01\uFF01"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\u6211\u5C31\u968F\u4FBF\u6D17\u6D17\u2026\u2026\u6211\u4E70\u4E86\u56E2\u8D2D\u5238\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u597D\u597D,\u770B\u4F60\u8FD9\u6837,\u4F60\u6700\u8FD1\u662F\u4E0D\u662F\u5F88\u7D2F\u554A\uFF1F"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u6211\u662F\u65C1\u767D"
    portrait: {fileID: 0}
    isLeftPortrait: 0
    text: "\uFF08\u6838\u9500\u4E86\u56E2\u8D2D\u5238\uFF09"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\u2026\u2026\u5927\u5BB6\u90FD\u8FD9\u6837\u5427\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u6211\u662F\u65C1\u767D"
    portrait: {fileID: 0}
    isLeftPortrait: 0
    text: "\u5C0F\u798F\u4F4E\u4E0B\u5934\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u6211\u662F\u65C1\u767D"
    portrait: {fileID: 0}
    isLeftPortrait: 0
    text: "\u4E0D\u77E5\u9053\u4EC0\u4E48\u65F6\u5019\u5F00\u59CB\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u6211\u662F\u65C1\u767D"
    portrait: {fileID: 0}
    isLeftPortrait: 0
    text: "\u9ED1\u8272\u7684\u6CE5\u5DF4\u5DF2\u7ECF\u9ECF\u5728\u4E86\u4ED6\u7684\u6BDB\u53D1\u4E0A\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\u54C7\u554A\u554A\u554A\u554A\u2014\u2014\uFF01\u8FD9\u662F\u4EC0\u4E48\uFF01\uFF01"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u4F60\u770B\u5F97\u89C1\u554A,\u53EF\u4EE5\u561B\uFF01"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u4F60\u7B97\u662F\u6709\u5929\u8D4B\u7684\u4E86\uFF01"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u8FD9\u4E2A\u7B97\u662F\u9F20\u4EEC\u8D1F\u9762\u60C5\u7EEA\u7684\u5B9E\u4F53\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u9F20\u4EEC\u5F88\u591A\u65F6\u5019\u5BDF\u89C9\u4E0D\u5230,\u4F46\u5B83\u786E\u5B9E\u5B58\u5728\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u6211\u6765\u5E2E\u4F60\u5427,\u7B97\u6253\u70CA\u524D\u7684\u6700\u540E\u4E00\u5355\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u6211\u662F\u65C1\u767D"
    portrait: {fileID: 0}
    isLeftPortrait: 0
    text: "\u70ED\u6C34\u6162\u6162\u51B2\u4E0B\u6765\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u6211\u662F\u65C1\u767D"
    portrait: {fileID: 0}
    isLeftPortrait: 0
    text: "\u4F60\u611F\u53D7\u5230\u4E86\u524D\u6240\u672A\u6709\u7684\u6E29\u6696(\u2741\xB4\u25E1`\u2741)"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\uFF08\u660E\u660E\u8FD8\u6709\u4E00\u5806\u4E8B\u60C5\u90FD\u6CA1\u89E3\u51B3\u3002\uFF09"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\uFF08\u4F46\u80F8\u53E3\u597D\u50CF\u7EC8\u4E8E\u80FD\u5598\u4E0A\u6C14\u4E86\u3002\uFF09"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\u597D\u795E\u5947\uFF01"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u597D\u4E86\uFF01\u611F\u89C9\u600E\u4E48\u6837?"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u6211\u8FD9\u91CC\u5176\u5B9E\u633A\u7F3A\u4EBA\u624B\u7684,\u8003\u8651\u8003\u8651\uFF1F"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\u6211\u4E0D\u4F1A\u554A......"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u4F60\u90FD\u80FD\u770B\u5230\u8FD9\u5C31\u8BF4\u660E\u4F60\u80AF\u5B9A\u80FD\u4F1A\u7684\uFF01"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u6211\u5F00\u7684\u5F85\u9047\u80AF\u5B9A\u6BD4\u4F60\u73B0\u5728\u7684\u516C\u53F8\u597D\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u81F3\u5C11\u4F60\u4E0D\u7528\u8FD9\u4E48\u665A\u624D\u6765\u6211\u8FD9\u513F,\u8FD8\u5E26\u7740\u8FD9\u4E48\u75B2\u60EB\u7684\u8EAB\u4F53\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u5305\u5403\u5305\u4F4F,\u4EE5\u4F60\u7684\u5929\u8D4B\u80AF\u5B9A\u7ED9\u4F60\u6BD4\u73B0\u5728\u5750\u529E\u516C\u5BA4\u7684\u5DE5\u8D44\u9AD8\u3002"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u6765\u4E0D\uFF1F\uFF01"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u5C0F\u798F"
    portrait: {fileID: 21300000, guid: f5d924d7c8541314a8a95fbd54653427, type: 3}
    isLeftPortrait: 0
    text: "\u6211\u8003\u8651\u8003\u8651......"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
  - speakerName: "\u91D1\u5AC2"
    portrait: {fileID: 21300000, guid: a06ba5c8fd04bef4a879a17fcf320943, type: 3}
    isLeftPortrait: 1
    text: "\u771F\u60F3\u6765\u660E\u5929\u4E0B\u5348\u5728\u8FD9\u513F\u7B49\u4F60\uFF01\u7ED9\u4F60\u5DE5\u88C5,\u660E\u5929\u7A7F\u8FD9\u4E2A\u6765\u627E\u6211\uFF01"
    backgroundImage: {fileID: 21300000, guid: 25660153abcce604d9a149d68b422020, type: 3}
