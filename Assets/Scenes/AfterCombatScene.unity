      isLeftPortrait: 0
      text: "\u4F60\u770B\u505C\u4E0B\u6765\u653E\u677E\u4E0B\u7684\u611F\u89C9\u53EF\u4EE5\u5427\uFF0C\u6211\u8FD9\u624B\u901F\u548B\u6837\uFF1F\u4E94\u661F\u597D\u8BC4\u5B89\u6392\u4E00\u4E0B\uFF1F"
