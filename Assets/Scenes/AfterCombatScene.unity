      isLeftPortrait: 1
      text: "\uFF08\u4ED6\u63E1\u7740\u90A3\u676F\u8336\uFF0C\u5FC3\u91CC\u611F\u5230\u65E0\u6BD4\u6E29\u6696\u3002\uFF09"
